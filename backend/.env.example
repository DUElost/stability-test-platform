DATABASE_URL=postgresql+asyncpg://stp:password@localhost:5432/stp
REDIS_URL=redis://localhost:6379/0
JWT_SECRET_KEY=change-me-in-production
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000
# CORS wildcards are rejected when credentials are enabled.
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type,X-Agent-Secret
SSH_CREDENTIALS_FERNET_KEY=
# STP_SSH_KNOWN_HOSTS=/etc/stp/known_hosts
# STP_SSH_LOG_ROOTS=/opt/stability-test-agent/logs,/var/log

HEARTBEAT_TIMEOUT_SECONDS=30
HEARTBEAT_CHECK_INTERVAL_SECONDS=10
BACKPRESSURE_LAG_THRESHOLD=5000
BACKPRESSURE_RELEASE_THRESHOLD=500
BACKPRESSURE_LOG_RATE_LIMIT=5

# NFS storage root shared between platform host and Linux agents.
# Defaults to /mnt/storage/test-platform when unset; used by script catalog,
# log writer, artifact uploader.
# STP_NFS_ROOT=/mnt/storage/test-platform

# Script catalog scan source on the platform host. When unset, defaults to
# ${STP_NFS_ROOT}/scripts. Override in dev to point at the repo:
# STP_SCRIPT_ROOT=F:\stability-test-platform\backend\agent\scripts

# Runtime root used by Linux agents after hot update. If set, script scan stores
# this path in script.nfs_path instead of the platform host's local scan path.
# STP_SCRIPT_RUNTIME_ROOT=/opt/stability-test-agent/agent/scripts

# Session watchdog (replaces overlapping recycler + heartbeat monitor checks)
USE_SESSION_WATCHDOG=true
# Long patrol + scan may delay HTTP heartbeat; 300s recommended for real-device hosts.
HOST_HEARTBEAT_TIMEOUT_SECONDS=300
UNKNOWN_GRACE_SECONDS=300
SESSION_WATCHDOG_INTERVAL_SECONDS=15

# WebSocket auth (see ADR-0009)
# ENV=development or production; production enforces valid WS_TOKEN
ENV=development
# Static shared secret for browser WS token validation (fallback when JWT unavailable)
WS_TOKEN=change-me-in-production
# Agent WS authentication secret (must match agent-side AGENT_SECRET)
AGENT_SECRET=change-me-in-production
# Agent claim version floor (POST /api/v1/agent/jobs/claim → 426 when below).
# Leave unset during rollout so old Agents keep claiming; set after fleet upgrade.
# STP_AGENT_MIN_VERSION=2.0.0

# ============================================
# Agent 热更新 / 首次安装
# ============================================
# Agent 主机 pip 镜像地址（热更新 requirements.txt 变化时注入 PIP_INDEX_URL）。
# 留空则用 pip 默认 index（公网 PyPI）。Agent 主机无法访问公网时填内网镜像。
# STP_AGENT_PIP_INDEX_URL=https://pypi.example.com/simple

# 控制平面预置 wheel 目录（首次安装离线兜底；Agent 主机无 pip 镜像时使用）。
# STP_AGENT_WHEELHOUSE=/opt/stp-wheelhouse

# ============================================
# ADR-0025 Sprint 4: Dedup scan + NFS 配置
# ============================================
# NFS/CIFS 根目录（后端与 Agent 共享，Agent 上送目标）
# STP_AEE_NFS_ROOT=/mnt/nfs/aee_events

# scan tool Python 解释器路径（后端 run_merge_sync 使用）
# STP_DEDUP_SCAN_PYTHON=/usr/bin/python3

# scan tool 脚本路径（指向 start_log_scan.py）
# STP_DEDUP_SCAN_SCRIPT=/opt/stability_Start-Log-Scan/start_log_scan.py

# scan tool 归属地（shanghai / factory，默认 shanghai）
# STP_DEDUP_SCAN_TAG=shanghai

# 终态自动 dedup 开关（1=开启, 0=关闭，默认 1）
# STP_DEDUP_AUTO_SCAN=1

# auto_archive_sweep 轮询间隔（秒，默认 120）
# AUTO_ARCHIVE_POLL_INTERVAL_SECONDS=120
# Plan 链持久化补偿扫描间隔（秒，默认 60）
# CHAIN_RECONCILER_INTERVAL_SECONDS=60

# ============================================
# ADR-0026: Plan 准入队列（P1,feature flag 默认关闭）
# ============================================
# 总开关:1=V2 准入队列(prepare 建 QUEUED,pump 准入);0=legacy 直派发。
# 注意:flag 关闭后 pump 仍以 drain-only 模式消化存量 QUEUED,不会静默搁置。
# STP_PLAN_ADMISSION_QUEUE_ENABLED=0
# pump 扫描间隔(秒,默认 5)
# STP_ADMISSION_PUMP_INTERVAL_SECONDS=5
# 每拍最多准入的 PlanRun 数(默认 5)
# STP_ADMISSION_PUMP_BATCH=5
# 准入竞争回队的重试退避(秒,默认 30)
# STP_ADMISSION_RETRY_BACKOFF_SECONDS=30
# 防饿 aging:每等待 N 秒等效提升 1 点优先级(默认 1800),上限 boost(默认 5,0=关闭)
# STP_ADMISSION_AGING_STEP_SECONDS=1800
# STP_ADMISSION_AGING_MAX_BOOST=5
# PRECHECK 中断恢复(reaper):最大重试次数(默认 3)与线性退避基数(秒,默认 60)
# MAX_ADMISSION_REQUEUE_ATTEMPTS=3
# ADMISSION_REQUEUE_BACKOFF_SECONDS=60

# ============================================
# Alembic downgrade 数据保护
# ============================================
# 数据迁移类 migration 的 downgrade 会全表 DELETE/drop 核心表（plan_run/plan 等），
# 误执行丢数据且不可恢复。guard_nonempty 在 downgrade 检测到目标表非空时抛错阻止。
# 确需强制回退（明确接受数据丢失）时设为 1：
#   STP_ALLOW_DESTRUCTIVE_DOWNGRADE=1 python -m alembic downgrade <rev>
# STP_ALLOW_DESTRUCTIVE_DOWNGRADE=0
