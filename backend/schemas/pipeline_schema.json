{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PipelineDefinition",
  "type": "object",
  "required": ["lifecycle"],
  "additionalProperties": false,
  "properties": {
    "lifecycle": {
      "type": "object",
      "required": ["init", "teardown"],
      "additionalProperties": false,
      "properties": {
        "timeout_seconds": { "type": "integer", "minimum": 1 },
        "init": { "$ref": "#/$defs/required_steps" },
        "patrol": {
          "type": "object",
          "required": ["interval_seconds", "steps"],
          "additionalProperties": false,
          "properties": {
            "interval_seconds": { "type": "integer", "minimum": 1 },
            "steps": { "$ref": "#/$defs/required_steps" }
          }
        },
        "teardown": { "$ref": "#/$defs/steps" }
      }
    }
  },
  "$defs": {
    "required_steps": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/step" }
    },
    "steps": {
      "type": "array",
      "items": { "$ref": "#/$defs/step" }
    },
    "step": {
      "type": "object",
      "required": ["step_id", "action", "version", "timeout_seconds"],
      "additionalProperties": false,
      "properties": {
        "step_id": { "type": "string", "minLength": 1 },
        "action": { "type": "string", "pattern": "^script:.+$" },
        "version": { "type": "string", "minLength": 1 },
        "params": { "type": "object", "default": {} },
        "timeout_seconds": { "type": "integer", "minimum": 1 },
        "retry": { "type": "integer", "minimum": 0, "maximum": 10, "default": 0 },
        "enabled": { "type": "boolean", "default": true }
      }
    }
  }
}
