{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PipelineDefinition",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/stages_format" },
    { "$ref": "#/$defs/lifecycle_format" }
  ],
  "$defs": {
    "stages_format": {
      "type": "object",
      "required": ["stages"],
      "additionalProperties": false,
      "properties": {
        "stages": { "$ref": "#/$defs/stages_object" }
      }
    },
    "lifecycle_format": {
      "type": "object",
      "required": ["lifecycle"],
      "additionalProperties": false,
      "properties": {
        "lifecycle": {
          "type": "object",
          "required": ["init", "teardown"],
          "additionalProperties": false,
          "properties": {
            "timeout_seconds": { "type": "integer", "minimum": 1 },
            "init": {
              "type": "object",
              "required": ["stages"],
              "additionalProperties": false,
              "properties": {
                "stages": { "$ref": "#/$defs/stages_object" }
              }
            },
            "patrol": {
              "type": "object",
              "required": ["stages", "interval_seconds"],
              "additionalProperties": false,
              "properties": {
                "interval_seconds": { "type": "integer", "minimum": 1 },
                "stages": { "$ref": "#/$defs/stages_object" }
              }
            },
            "teardown": {
              "type": "object",
              "required": ["stages"],
              "additionalProperties": false,
              "properties": {
                "stages": { "$ref": "#/$defs/stages_object" }
              }
            }
          }
        }
      }
    },
    "stages_object": {
      "type": "object",
      "properties": {
        "prepare":      { "$ref": "#/$defs/stage" },
        "execute":      { "$ref": "#/$defs/stage" },
        "post_process": { "$ref": "#/$defs/stage" }
      },
      "additionalProperties": false
    },
    "stage": {
      "type": "array",
      "items": { "$ref": "#/$defs/step" }
    },
    "step": {
      "type": "object",
      "required": ["step_id", "action", "timeout_seconds"],
      "additionalProperties": false,
      "properties": {
        "step_id":         { "type": "string", "minLength": 1 },
        "action":          { "type": "string", "pattern": "^(tool:\\d+|builtin:.+|script:.+)$" },
        "version":         { "type": "string", "minLength": 1 },
        "params":          { "type": "object", "default": {} },
        "timeout_seconds": { "type": "integer", "minimum": 1 },
        "retry":           { "type": "integer", "minimum": 0, "maximum": 10, "default": 0 },
        "enabled":         { "type": "boolean", "default": true }
      },
      "if":   { "properties": { "action": { "pattern": "^(tool:|script:)" } }, "required": ["action"] },
      "then": { "required": ["version"] }
    }
  }
}
