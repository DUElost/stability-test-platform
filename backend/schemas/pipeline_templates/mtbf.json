{
  "version": 1,
  "description": "MTBF test: push resources, install APK, run instrumentation test, collect logs",
  "phases": [
    {
      "name": "prepare",
      "parallel": false,
      "steps": [
        {
          "name": "check_device",
          "action": "builtin:check_device",
          "params": {},
          "timeout": 30,
          "on_failure": "stop"
        },
        {
          "name": "ensure_root",
          "action": "builtin:ensure_root",
          "params": {},
          "timeout": 30,
          "on_failure": "continue"
        },
        {
          "name": "push_resources",
          "action": "builtin:push_resources",
          "params": {
            "files": []
          },
          "timeout": 300,
          "on_failure": "continue"
        },
        {
          "name": "install_apk",
          "action": "builtin:install_apk",
          "params": {
            "apk_path": "{apk_path}",
            "reinstall": true
          },
          "timeout": 120,
          "on_failure": "stop"
        }
      ]
    },
    {
      "name": "execute",
      "parallel": false,
      "steps": [
        {
          "name": "run_instrument",
          "action": "builtin:run_instrument",
          "params": {
            "runner": "com.transsion.stresstest.test/androidx.test.runner.AndroidJUnitRunner",
            "instrument_args": {},
            "timeout": 86400
          },
          "timeout": 86400,
          "on_failure": "stop"
        }
      ]
    },
    {
      "name": "post_process",
      "parallel": false,
      "steps": [
        {
          "name": "scan_aee",
          "action": "builtin:scan_aee",
          "params": {
            "aee_dirs": ["/data/aee_exp", "/data/vendor/aee_exp"],
            "local_dir": "{log_dir}/aee"
          },
          "timeout": 120,
          "on_failure": "continue"
        },
        {
          "name": "log_scan",
          "action": "builtin:log_scan",
          "params": {
            "input_dir": "{log_dir}",
            "keywords": ["FATAL", "CRASH", "ANR"]
          },
          "timeout": 120,
          "on_failure": "continue"
        }
      ]
    }
  ]
}
