{
  "version": 1,
  "description": "MTBF test: push resources, install APK, run instrumentation test, collect logs",
  "lifecycle": {
    "timeout_seconds": 7200,
    "init": [
      {
        "step_id": "check_device",
        "action": "script:check_device",
        "version": "1.0.0",
        "timeout_seconds": 30,
        "retry": 1,
        "params": {}
      },
      {
        "step_id": "ensure_root",
        "action": "script:ensure_root",
        "version": "1.0.0",
        "timeout_seconds": 60,
        "retry": 1,
        "params": {
          "max_attempts": 3
        }
      }
    ],
    "teardown": []
  }
}
