{
  "version": 1,
  "description": "Standby test: play video, optionally turn off screen, wait for standby duration",
  "stages": {
    "prepare": [
      {
        "step_id": "check_device",
        "action": "builtin:check_device",
        "timeout_seconds": 30,
        "retry": 0,
        "params": {}
      }
    ],
    "execute": [
      {
        "step_id": "start_video",
        "action": "builtin:start_process",
        "timeout_seconds": 30,
        "retry": 0,
        "params": {
          "timeout": 30,
          "command": "am start -a android.intent.action.VIEW -d {video_url}",
          "background": false
        }
      },
      {
        "step_id": "standby_wait",
        "action": "builtin:start_process",
        "timeout_seconds": 7200,
        "retry": 0,
        "params": {
          "command": "sleep {standby_seconds}",
          "background": false,
          "timeout": 7200
        }
      }
    ],
    "post_process": []
  }
}
