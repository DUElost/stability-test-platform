{
  "version": 1,
  "description": "Standard Android Monkey test: run monkey with specified packages, event count, and throttle",
  "phases": [
    {
      "name": "prepare",
      "parallel": false,
      "steps": [
        {
          "name": "check_device",
          "action": "builtin:check_device",
          "params": {},
          "timeout": 30,
          "on_failure": "stop"
        }
      ]
    },
    {
      "name": "execute",
      "parallel": false,
      "steps": [
        {
          "name": "run_monkey",
          "action": "builtin:start_process",
          "params": {
            "command": "monkey -p {packages} --throttle {throttle} {event_count}",
            "background": false,
            "timeout": 3600
          },
          "timeout": 3600,
          "on_failure": "stop"
        }
      ]
    },
    {
      "name": "teardown",
      "parallel": false,
      "steps": []
    }
  ]
}
