{
  "version": 1,
  "description": "Standard Android Monkey test: run monkey with specified packages, event count, and throttle",
  "stages": {
    "prepare": [
      {
        "step_id": "check_device",
        "action": "builtin:check_device",
        "timeout_seconds": 30,
        "retry": 0,
        "params": {}
      }
    ],
    "execute": [
      {
        "step_id": "run_monkey",
        "action": "builtin:start_process",
        "timeout_seconds": 3600,
        "retry": 0,
        "params": {
          "timeout": 3600,
          "command": "monkey -p {packages} --throttle {throttle} {event_count}",
          "background": false
        }
      }
    ],
    "post_process": []
  }
}
