{
  "version": 1,
  "description": "Monkey AEE Stability test: run external legacy script via subprocess adapter",
  "stages": {
    "prepare": [
      {
        "step_id": "check_device",
        "action": "builtin:check_device",
        "timeout_seconds": 30,
        "retry": 0,
        "params": {}
      }
    ],
    "execute": [
      {
        "step_id": "run_legacy_script",
        "action": "builtin:run_tool_script",
        "timeout_seconds": 21600,
        "retry": 0,
        "params": {
          "script_class": "MonkeyAEEStabilityTest",
          "script_path": "{legacy_script_path}"
        }
      }
    ],
    "post_process": [
      {
        "step_id": "scan_aee",
        "action": "builtin:scan_aee",
        "timeout_seconds": 120,
        "retry": 0,
        "params": {
          "local_dir": "{log_dir}/aee",
          "aee_dirs": [
            "/data/aee_exp",
            "/data/vendor/aee_exp"
          ]
        }
      },
      {
        "step_id": "log_scan",
        "action": "builtin:log_scan",
        "timeout_seconds": 120,
        "retry": 0,
        "params": {
          "input_dir": "{log_dir}",
          "keywords": [
            "FATAL",
            "CRASH",
            "ANR"
          ]
        }
      }
    ]
  }
}
