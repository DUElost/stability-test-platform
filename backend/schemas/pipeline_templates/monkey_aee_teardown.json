{
  "version": 1,
  "description": "Monkey AEE stability test - teardown (run once on terminate)",
  "lifecycle": {
    "timeout_seconds": 604800,
    "init": [
      {
        "step_id": "check_device",
        "action": "script:check_device",
        "version": "1.0.0",
        "timeout_seconds": 30,
        "retry": 1,
        "params": {}
      },
      {
        "step_id": "ensure_root",
        "action": "script:ensure_root",
        "version": "1.0.0",
        "timeout_seconds": 60,
        "retry": 1,
        "params": {
          "max_attempts": 3
        }
      },
      {
        "step_id": "monkey_setup",
        "action": "script:monkey_setup",
        "version": "1.0.0",
        "timeout_seconds": 600,
        "retry": 1,
        "params": {}
      },
      {
        "step_id": "monkey_resource_push",
        "action": "script:monkey_resource_push",
        "version": "1.0.0",
        "timeout_seconds": 600,
        "retry": 1,
        "params": {}
      },
      {
        "step_id": "monkey_launch",
        "action": "script:monkey_launch",
        "version": "5.0.0",
        "timeout_seconds": 1200,
        "retry": 0,
        "params": {}
      }
    ],
    "patrol": {
      "interval_seconds": 300,
      "steps": [
        {
          "step_id": "monkey_check",
          "action": "script:monkey_check",
          "version": "1.0.0",
          "timeout_seconds": 60,
          "retry": 0,
          "params": {}
        }
      ]
    },
    "teardown": [
      {
        "step_id": "monkey_teardown",
        "action": "script:monkey_teardown",
        "version": "1.0.0",
        "timeout_seconds": 600,
        "retry": 0,
        "params": {}
      }
    ]
  }
}
