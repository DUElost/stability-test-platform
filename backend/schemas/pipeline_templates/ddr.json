{
  "version": 1,
  "description": "DDR memory test: push memtester binary, run memtester with specified size and loops",
  "phases": [
    {
      "name": "prepare",
      "parallel": false,
      "steps": [
        {
          "name": "check_device",
          "action": "builtin:check_device",
          "params": {},
          "timeout": 30,
          "on_failure": "stop"
        },
        {
          "name": "ensure_root",
          "action": "builtin:ensure_root",
          "params": {},
          "timeout": 30,
          "on_failure": "stop"
        },
        {
          "name": "push_memtester",
          "action": "builtin:push_resources",
          "params": {
            "files": [
              {"local": "{memtester_path}", "remote": "/data/local/tmp/memtester", "chmod": "755"}
            ]
          },
          "timeout": 60,
          "on_failure": "stop"
        }
      ]
    },
    {
      "name": "execute",
      "parallel": false,
      "steps": [
        {
          "name": "run_memtester",
          "action": "builtin:start_process",
          "params": {
            "command": "/data/local/tmp/memtester {mem_size_mb}M {loops}",
            "background": false,
            "timeout": 7200
          },
          "timeout": 7200,
          "on_failure": "stop"
        }
      ]
    },
    {
      "name": "teardown",
      "parallel": false,
      "steps": []
    }
  ]
}
