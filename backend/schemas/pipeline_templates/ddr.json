{
  "version": 1,
  "description": "DDR memory test: push memtester binary, run memtester with specified size and loops",
  "stages": {
    "prepare": [
      {
        "step_id": "check_device",
        "action": "builtin:check_device",
        "timeout_seconds": 30,
        "retry": 0,
        "params": {}
      },
      {
        "step_id": "ensure_root",
        "action": "builtin:ensure_root",
        "timeout_seconds": 30,
        "retry": 0,
        "params": {}
      },
      {
        "step_id": "push_memtester",
        "action": "builtin:push_resources",
        "timeout_seconds": 60,
        "retry": 0,
        "params": {
          "files": [
            {
              "local": "{memtester_path}",
              "remote": "/data/local/tmp/memtester",
              "chmod": "755"
            }
          ]
        }
      }
    ],
    "execute": [
      {
        "step_id": "run_memtester",
        "action": "builtin:start_process",
        "timeout_seconds": 7200,
        "retry": 0,
        "params": {
          "timeout": 7200,
          "command": "/data/local/tmp/memtester {mem_size_mb}M {loops}",
          "background": false
        }
      }
    ],
    "post_process": []
  }
}
