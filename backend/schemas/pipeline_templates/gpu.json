{
  "version": 1,
  "description": "GPU stress test: install APK, launch benchmark activity in loops",
  "stages": {
    "prepare": [
      {
        "step_id": "check_device",
        "action": "builtin:check_device",
        "timeout_seconds": 30,
        "retry": 0,
        "params": {}
      },
      {
        "step_id": "ensure_root",
        "action": "builtin:ensure_root",
        "timeout_seconds": 30,
        "retry": 0,
        "params": {}
      },
      {
        "step_id": "install_apk",
        "action": "builtin:install_apk",
        "timeout_seconds": 120,
        "retry": 0,
        "params": {
          "reinstall": true,
          "apk_path": "{apk_path}"
        }
      }
    ],
    "execute": [
      {
        "step_id": "run_gpu_benchmark",
        "action": "builtin:start_process",
        "timeout_seconds": 600,
        "retry": 0,
        "params": {
          "timeout": 600,
          "command": "am start -n {activity}",
          "background": false
        }
      }
    ],
    "post_process": []
  }
}
