{
  "version": 1,
  "description": "GPU stress test: install APK, launch benchmark activity in loops",
  "phases": [
    {
      "name": "prepare",
      "parallel": false,
      "steps": [
        {
          "name": "check_device",
          "action": "builtin:check_device",
          "params": {},
          "timeout": 30,
          "on_failure": "stop"
        },
        {
          "name": "ensure_root",
          "action": "builtin:ensure_root",
          "params": {},
          "timeout": 30,
          "on_failure": "continue"
        },
        {
          "name": "install_apk",
          "action": "builtin:install_apk",
          "params": {
            "apk_path": "{apk_path}",
            "reinstall": true
          },
          "timeout": 120,
          "on_failure": "stop"
        }
      ]
    },
    {
      "name": "execute",
      "parallel": false,
      "steps": [
        {
          "name": "run_gpu_benchmark",
          "action": "builtin:start_process",
          "params": {
            "command": "am start -n {activity}",
            "background": false,
            "timeout": 600
          },
          "timeout": 600,
          "on_failure": "continue"
        }
      ]
    },
    {
      "name": "teardown",
      "parallel": false,
      "steps": []
    }
  ]
}
