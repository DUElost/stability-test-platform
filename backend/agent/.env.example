# Stability Test Platform Agent 配置文件
# 复制此文件为 .env 并根据实际情况修改配置

# ============================================
# 服务器配置
# ============================================
# 后端服务器地址
# - 生产 / 预发布 Linux 控制平面：使用固定域名或固定 IP（如 http://172.21.10.15:8000）
# - WSL / 本机开发联调：使用 http://127.0.0.1:8000
API_URL=http://127.0.0.1:8000

# ============================================
# 主机配置
# ============================================
# 主机 ID
# - 生产默认使用固定正整数，必须与后端 hosts.id 一致
# - 仅临时实验环境才建议启用 AUTO_REGISTER_HOST=true
HOST_ID=1
AUTO_REGISTER_HOST=false

# ── ADR-0026 Step 5b: 并发模型（新语义） ──
# 注意：MAX_CONCURRENT_TASKS 已废弃 — 不再限制同时运行的 Job 数。
# 全部入场设备都可以是 RUNNING；瞬时脚本/ADB 并发由 OperationScheduler 独立限制。

# Worker 线程池大小（默认 50，覆盖本 host 全部设备）
# STP_JOB_WORKER_POOL_SIZE=50

# 每 host 瞬时脚本/ADB 并发上限（默认 5，可热调）
# STP_MAX_CONCURRENT_OPERATIONS=5

# 后台 Coordinator 心跳间隔（秒，默认 30）
# COORDINATOR_HEARTBEAT_INTERVAL=30

# INIT→PATROL 阶段屏障（同 PlanRunHost 设备对齐后再开长跑；默认开启）
# STP_PHASE_BARRIER_ENABLED=1
# 屏障等待上限（秒，默认 600）
# STP_BARRIER_TIMEOUT_SECONDS=600

# ADR-0026 P0: 采纳控制面 heartbeat_interval_seconds 时的钳位（秒）
# STP_HEARTBEAT_INTERVAL_MIN=10
# STP_HEARTBEAT_INTERVAL_MAX=120

# 旧变量（仅向后兼容，不再用于并发控制）
# MAX_CONCURRENT_TASKS=2

# ============================================
# 采集配置
# ============================================
# 心跳间隔（秒）- 建议设置为 10
POLL_INTERVAL=10

# 挂载点检查（逗号分隔，留空则不检查）
# 示例：/mnt/data,/mnt/logs,/mnt/sdcard
MOUNT_POINTS=

# ============================================
# ADB 配置
# ============================================
# ADB 可执行文件路径
ADB_PATH=adb

# ADB 服务端口（默认 5037）
# WSL 环境下若默认端口被占用需切换端口（如 5039），必须在此配置，
# 否则 sudo 运行 agent 时无法继承 shell 中设置的 ANDROID_ADB_SERVER_PORT
# ANDROID_ADB_SERVER_PORT=5037

# ============================================
# 日志配置
# ============================================
# 日志级别：DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================
# 可选：高级配置
# ============================================
# 任务执行超时时间（秒）
TASK_TIMEOUT=3600

# 单次拉取任务数量上限
BATCH_SIZE=10

# 设备发现超时时间（秒）
DEVICE_DISCOVERY_TIMEOUT=30

# 设备锁租约时长（秒，锁过期后 watchdog 回收设备）
# DEVICE_LOCK_LEASE_SECONDS=600

# 锁续期间隔（秒）
# AGENT_LOCK_RENEWAL_INTERVAL=60

# ============================================
# WebSocket 配置
# ============================================
# Agent WebSocket 连接到后端的 URL（自动从 API_URL 推导，通常不需要手动设置）
# WS_URL=ws://127.0.0.1:8000/ws/agent

# Agent 认证密钥（需与后端 AGENT_SECRET 环境变量一致）
# AGENT_SECRET=

# pip 镜像地址（热更新 requirements.txt 变化时由控制平面注入 PIP_INDEX_URL；
# 也可在此预设，供 Agent 本机手动 pip install 使用）
# PIP_INDEX_URL=https://pypi.example.com/simple

# WebSocket 重连最大延迟（秒，指数退避上限）
# WS_RECONNECT_MAX_DELAY=30

# WebSocket ping/pong 保活间隔（秒）
# WS_PING_INTERVAL=30

# WebSocket 消息缓冲区大小（断线期间最大缓存消息数）
# WS_BUFFER_SIZE=1000

# ============================================
# 可选：资源与工具路径
# ============================================
# AIMONKEY 资源目录（包含 aim, aim.jar 等文件）
# AIMONKEY_RESOURCE_DIR=/opt/stability-test-agent/resources/aimonkey

# 外部测试工具扫描目录
# EXTERNAL_TOOL_DIR=/home/android/sonic_agent/logs/ftp_log/sonic_tinno/Test_Tool

# Agent 安装目录（通常不需要手动设置，安装脚本会自动处理）
# AGENT_INSTALL_DIR=/opt/stability-test-agent

# ============================================
# ADR-0025 Sprint 4: Dedup scan + 上送配置
# ============================================
# scan tool Python 解释器路径（必须）
# STP_DEDUP_SCAN_PYTHON=/usr/bin/python3

# scan tool 脚本路径（必须，指向 start_log_scan.py）
# STP_DEDUP_SCAN_SCRIPT=/opt/stability_Start-Log-Scan/start_log_scan.py

# scan tool 归属地（shanghai / factory，默认 shanghai）
# STP_DEDUP_SCAN_TAG=shanghai

# Agent HDD 根目录（AEE 事件存储路径，默认 /mnt/hdd/aee_events）
# STP_AEE_LOCAL_ROOT=/mnt/hdd/aee_events

# NFS/CIFS 根目录（Agent 上送目标，与后端 STP_AEE_NFS_ROOT 一致）
# STP_AEE_NFS_ROOT=/mnt/nfs/aee_events

# CIFS 根目录（可选，留空时回退到 STP_AEE_NFS_ROOT）
# STP_AEE_CIFS_ROOT=

# 终态自动 dedup 开关（1=开启, 0=关闭，默认 1）
# STP_DEDUP_AUTO_SCAN=1
