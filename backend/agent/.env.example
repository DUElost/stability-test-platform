# Stability Test Platform Agent 配置文件
# 复制此文件为 .env 并根据实际情况修改配置

# ============================================
# 服务器配置
# ============================================
# 后端服务器地址
API_URL=http://127.0.0.1:8000

# ============================================
# 主机配置
# ============================================
# 主机 ID（必须与后端 hosts.id 一致，且必须大于 0）
# 请勿使用 0，否则 Agent 将拒绝启动
HOST_ID=1

# ============================================
# 采集配置
# ============================================
# 心跳间隔（秒）- 建议设置为 10
POLL_INTERVAL=10

# 挂载点检查（逗号分隔，留空则不检查）
# 示例：/mnt/data,/mnt/logs,/mnt/sdcard
MOUNT_POINTS=

# ============================================
# ADB 配置
# ============================================
# ADB 可执行文件路径
ADB_PATH=adb

# ============================================
# 日志配置
# ============================================
# 日志级别：DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================
# 可选：高级配置
# ============================================
# 任务执行超时时间（秒）
TASK_TIMEOUT=3600

# 单次拉取任务数量上限
BATCH_SIZE=10

# 设备发现超时时间（秒）
DEVICE_DISCOVERY_TIMEOUT=30
