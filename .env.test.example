# pytest 环境变量模板（复制为 .env.test 后按需修改）
# 用法: set -a && source .env.test && set +a && python -m pytest backend/agent/tests/ -q

TESTING=1
JWT_SECRET_KEY=test-secret-key-for-ci-32-bytes-ok
AGENT_SECRET=

# 与 CI (.github/workflows/ci.yml) 对齐；本地 PostgreSQL 须先建库:
#   sudo -u postgres psql -c "CREATE DATABASE stability_test;"
TEST_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/stability_test
