# Normalize all text files to LF in the repo; Windows checkouts will get
# CRLF in the working tree automatically. Eliminates EOL noise that has
# polluted PlanEditPage.tsx multiple times in this project's history.
* text=auto eol=lf

# --- Explicit text declarations -------------------------------------------
# Why: git's auto-detection samples the first 8000 bytes and falls back to
# "binary" when the high-bit-byte ratio is high. Files with heavy CJK
# content (UTF-8 Chinese is 3 bytes/char, often >30% high-bit) get
# misclassified as binary -> `i/-text` in `git ls-files --eol`, EOL
# normalization disabled, diff shown as "Binary files differ". Forcing
# `text` here removes that ambiguity for every source/markup format
# the repo actually uses.
*.ts         text eol=lf
*.tsx        text eol=lf
*.js         text eol=lf
*.jsx        text eol=lf
*.mjs        text eol=lf
*.cjs        text eol=lf
*.py         text eol=lf
*.md         text eol=lf
*.json       text eol=lf
*.html       text eol=lf
*.css        text eol=lf
*.scss       text eol=lf
*.toml       text eol=lf
*.ini        text eol=lf
*.cfg        text eol=lf
*.conf       text eol=lf
*.env.example text eol=lf

# --- LF-mandatory (Linux runtime) ----------------------------------------
# Shell scripts the Agent installer ships to Linux hosts + YAML pipelines.
*.sh         text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf

# --- Windows-native (must keep CRLF) -------------------------------------
*.bat        text eol=crlf
*.cmd        text eol=crlf
*.ps1        text eol=crlf

# --- Explicit binary -----------------------------------------------------
# Git will not attempt EOL conversion or text diff for these.
*.png        binary
*.jpg        binary
*.jpeg       binary
*.gif        binary
*.ico        binary
*.pdf        binary
*.zip        binary
*.gz         binary
*.tar        binary
*.woff       binary
*.woff2      binary
*.ttf        binary
*.eot        binary
*.db         binary
*.sqlite     binary
*.sqlite3    binary
