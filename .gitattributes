# Auto-detect all text files and normalize to LF
* text=auto eol=lf

# Shell scripts
*.sh eol=lf
*.bash eol=lf

# Python
*.py eol=lf

# Frontend
*.ts eol=lf
*.tsx eol=lf
*.js eol=lf
*.jsx eol=lf
*.css eol=lf

# Config / data
*.json eol=lf
*.yaml eol=lf
*.yml eol=lf
*.txt eol=lf
*.md eol=lf
*.cfg eol=lf
*.ini eol=lf
*.env eol=lf
*.example eol=lf
*.template eol=lf

# Windows scripts
*.bat eol=crlf
*.ps1 eol=crlf
*.cmd eol=crlf

# Binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.jar binary
*.apk binary
*.db binary
*.sqlite3 binary
