# Server environment for Docker Compose development only.
# Use a dedicated checkout and keep it isolated from production.

# Postgres / Redis (container-internal addresses; docker-compose.yml rewires DATABASE_URL)
DATABASE_URL=postgresql+asyncpg://stp:change-me-local@postgres:5432/stp_dev

# Redis (default matches docker-compose.yml service)
REDIS_URL=redis://redis:6379/0
CORS_ORIGINS=http://127.0.0.1:15173,http://localhost:15173

# JWT secret - replace with a strong random value before non-local use
JWT_SECRET_KEY=change-me-in-production
STP_ADMIN_USER=admin
STP_ADMIN_PASSWORD=admin123

# Linux-first dev defaults
ENV=development
AUTH_COOKIE_SECURE=0
AUTH_COOKIE_SAMESITE=lax
STP_CSRF_ENABLED=1
AGENT_SECRET=change-me-in-development
STP_SCRIPT_ROOT=/app/backend/agent/scripts
STP_NFS_ROOT=/var/lib/stp-dev/nfs
STP_AEE_NFS_ROOT=/var/lib/stp-dev/aee-nfs
STP_AEE_LOCAL_ROOT=/var/lib/stp-dev/aee-local

# Logging
LOG_LEVEL=INFO
