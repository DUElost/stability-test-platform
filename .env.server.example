# Server environment for Docker Compose
# Copy this file to .env.server and replace placeholder secrets before use.

# Postgres (default matches docker-compose.yml service)
DATABASE_URL=postgresql+asyncpg://stp:password@postgres:5432/stp

# Redis (default matches docker-compose.yml service)
REDIS_URL=redis://redis:6379/0

# JWT secret - replace with a strong random value before non-local use
JWT_SECRET_KEY=change-me-in-production

# Logging
LOG_LEVEL=INFO
