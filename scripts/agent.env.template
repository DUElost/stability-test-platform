# Stability Test Agent 环境配置模板
# 复制为 config/agent.env 并根据实际情况修改

# ================================================
# API 配置 (必填)
# ================================================

# 后端 API 地址
API_URL=http://172.21.10.5:8000

# Host Agent ID (在平台注册的主机ID)
HOST_ID=1

# ================================================
# ADB 配置
# ================================================

# ADB 可执行文件路径
ADB_PATH=adb

# ================================================
# AIMONKEY 配置
# ================================================

# AIMONKEY 资源文件目录
AIMONKEY_RESOURCE_DIR=/opt/stability-test-agent/resources/aimonkey

# 日志根目录
LOG_DIR=/opt/stability-test-agent/logs

# ================================================
# Python 配置
# ================================================

# Python 模块搜索路径
PYTHONPATH=/opt/stability-test-agent

# 日志级别 (DEBUG/INFO/WARNING/ERROR)
LOG_LEVEL=INFO

# ================================================
# 高级配置 (可选)
# ================================================

# 心跳间隔 (秒)
# HEARTBEAT_INTERVAL=60

# 任务轮询间隔 (秒)
# POLL_INTERVAL=5

# 设备锁超时 (秒)
# DEVICE_LOCK_TIMEOUT=300
