# Server environment for Docker Compose
# Postgres (default matches docker-compose.yml service)
DATABASE_URL=postgresql+asyncpg://stp:password@postgres:5432/stp

# Redis (default matches docker-compose.yml service)
REDIS_URL=redis://redis:6379/0

# JWT secret - MUST be changed in production!
JWT_SECRET_KEY=stp-dev-secret-key-change-in-production

# Logging
LOG_LEVEL=INFO
